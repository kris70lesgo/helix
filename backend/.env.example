# AEGIS Backend Environment Variables
# Copy this to .env and fill in your values

# Required: OpenRouter API key for AI analysis
# Get one at: https://openrouter.ai/keys (sign up, click "Create API Key")
# Models: tencent/hy3-preview:free (free), google/gemma-3n-e4b-it:free, deepseek/deepseek-r1:free
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your API key
#   source .env && uvicorn main:app --reload

OPENROUTER_API_KEY=your_openrouter_api_key_here